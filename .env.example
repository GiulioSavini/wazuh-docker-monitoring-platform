# =============================================================================
# Wazuh Docker Monitoring Platform — Environment Configuration
# Copy this file to .env and fill in the values before deploying.
# =============================================================================

# -- Wazuh Version ------------------------------------------------------------
WAZUH_VERSION=4.9.0

# -- Indexer -------------------------------------------------------------------
INDEXER_HEAP=1g
INDEXER_PORT=9200
INDEXER_USERNAME=admin
INDEXER_PASSWORD=CHANGE_ME_indexer_password

# -- Manager -------------------------------------------------------------------
MANAGER_API_PORT=55000
AGENT_PORT=1514
SYSLOG_PORT=1515
API_USERNAME=wazuh-wui
API_PASSWORD=CHANGE_ME_api_password

# -- Dashboard -----------------------------------------------------------------
DASHBOARD_PORT=5601
DASHBOARD_USERNAME=kibanaserver
DASHBOARD_PASSWORD=CHANGE_ME_dashboard_password

# -- NGINX (optional, enable with --profile with-nginx) -----------------------
NGINX_HTTPS_PORT=443

# -- Network -------------------------------------------------------------------
WAZUH_SUBNET=172.25.0.0/24

# -- Filebeat ------------------------------------------------------------------
FILEBEAT_SSL_VERIFY=full
