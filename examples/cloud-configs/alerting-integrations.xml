<!--
  Wazuh Alerting Integrations
  Add these blocks inside <ossec_config> in the Wazuh Manager config.
  Each integration sends alerts matching certain rule levels to external systems.
-->

<!-- ======================================================================= -->
<!-- SLACK — send high-severity alerts to a Slack channel                    -->
<!-- ======================================================================= -->
<!--
  Prerequisites:
  1. Create a Slack Incoming Webhook: https://api.slack.com/messaging/webhooks
  2. Set the webhook URL below
-->
<integration>
  <name>slack</name>
  <hook_url>https://hooks.slack.com/services/YOUR/WEBHOOK/URL</hook_url>
  <level>10</level>
  <alert_format>json</alert_format>
  <!-- Optional: filter by rule group -->
  <!-- <group>docker_security,linux_privesc,aws_auth</group> -->
</integration>

