<!--
  AWS CloudTrail Integration Example
  Add this block inside <ossec_config> in the Wazuh Manager configuration.
  Docs: https://documentation.wazuh.com/current/cloud-security/amazon/services/cloudtrail.html
-->

<!-- Option A: S3 bucket with IAM role (recommended for EC2-hosted managers) -->
<wodle name="aws-s3">
  <disabled>no</disabled>
  <interval>10m</interval>
  <run_on_start>yes</run_on_start>
  <skip_on_error>yes</skip_on_error>

  <bucket type="cloudtrail">
    <name>my-cloudtrail-bucket</name>
    <!-- Use IAM role if running on EC2, otherwise provide keys -->
    <!-- <access_key>AKIAIOSFODNN7EXAMPLE</access_key> -->
    <!-- <secret_key>wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY</secret_key> -->
    <region>eu-west-1</region>
    <path>AWSLogs/123456789012/CloudTrail</path>
    <only_logs_after>2024-01-01</only_logs_after>
  </bucket>
</wodle>

